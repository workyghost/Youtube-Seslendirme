{
  "manifest_version": 3,
  "name": "YouTube Translator Pro",
  "version": "3.0",
  "description": "YouTube videolarını Türkçe'ye çevirir ve eş zamanlı seslendirir. (Gemini 3.1 Flash Lite)",
  "permissions": ["storage", "activeTab", "tts"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.mjs",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["transcript-fetcher.js", "sync-engine.js", "cleanup-manager.js", "content.js"],
      "css": ["styles.css"]
    }
  ]
}
